{
  "title": "k6 Performance Report",
  "panels": [
    {
      "type": "stat",
      "title": "Avg Response Time (ms)",
      "gridPos": {"x":0,"y":0,"w":6,"h":4},
      "datasource": "influxdb",
      "targets": [{
        "rawQuery": true,
        "query": "SELECT mean(\"value\") FROM \"http_req_duration\" WHERE $timeFilter",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "title": "p95 Response Time (ms)",
      "gridPos": {"x":6,"y":0,"w":6,"h":4},
      "datasource": "influxdb",
      "targets": [{
        "rawQuery": true,
        "query": "SELECT percentile(\"value\", 95) FROM \"http_req_duration\" WHERE $timeFilter",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "title": "Total Requests",
      "gridPos": {"x":12,"y":0,"w":6,"h":4},
      "datasource": "influxdb",
      "targets": [{
        "rawQuery": true,
        "query": "SELECT count(\"value\") FROM \"http_reqs\" WHERE $timeFilter",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "title": "Error Rate",
      "gridPos": {"x":18,"y":0,"w":6,"h":4},
      "datasource": "influxdb",
      "targets": [{
        "rawQuery": true,
        "query": "SELECT mean(\"value\") FROM \"http_req_failed\" WHERE $timeFilter",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Response Time Over Time (ms)",
      "gridPos": {"x":0,"y":4,"w":24,"h":8},
      "datasource": "influxdb",
      "targets": [{
        "rawQuery": true,
        "query": "SELECT mean(\"value\") FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(none)",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Virtual Users Over Time",
      "gridPos": {"x":0,"y":12,"w":12,"h":8},
      "datasource": "influxdb",
      "targets": [{
        "rawQuery": true,
        "query": "SELECT mean(\"value\") FROM \"vus\" WHERE $timeFilter GROUP BY time($__interval) fill(none)",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Requests Per Second",
      "gridPos": {"x":12,"y":12,"w":12,"h":8},
      "datasource": "influxdb",
      "targets": [{
        "rawQuery": true,
        "query": "SELECT sum(\"value\") FROM \"http_reqs\" WHERE $timeFilter GROUP BY time($__interval) fill(none)",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Auth User Info Response Time",
      "gridPos": {"x":0,"y":20,"w":24,"h":8},
      "datasource": "influxdb",
      "targets": [{
        "rawQuery": true,
        "query": "SELECT mean(\"value\") FROM \"auth_user_info_time\" WHERE $timeFilter GROUP BY time($__interval) fill(none)",
        "refId": "A"
      }]
    }
  ],
  "schemaVersion": 36,
  "version": 2,
  "refresh": "5s",
  "time": {"from": "now-1h", "to": "now"}
}